@* Components/Pages/Orders/OrderUpdate.razor *@
@page "/orders/update/{id:int}"
@rendermode InteractiveServer
@inject OrderUpdateDtoService OrderService
@inject NavigationManager Nav

<h2>Update Order</h2>

@if (order == null)
{
    <p>Loading...</p>
}
else
{
    <div>
        <label>ClientId</label>
        <input type="number" @bind="order.ClientId" />
    </div>
    <div>
        <label>SupplierId</label>
        <input type="number" @bind="order.SupplierId" />
    </div>
    <div>
        <label>GoodId</label>
        <input type="number" @bind="order.GoodsId" />
    </div>
    <div>
        <label>Quantity</label>
        <input type="number" @bind="order.Quantity" />
    </div>

    <button @onclick="Submit">Save</button>
    <button @onclick='() => Nav.NavigateTo("/orders")'>Cancel</button>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <p style="color:red;">@errorMessage</p>
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private OrderUpdateDto? order;
    private string? errorMessage;

    protected override async Task OnInitializedAsync() =>
        order = await OrderService.GetByIdAsync(Id);

    private async Task Submit()
    {
        if (order!.ClientId <= 0)
        {
            errorMessage = "ClientId is required.";
            return;
        }
        if (order!.SupplierId <= 0)
        {
            errorMessage = "SupplierId is required.";
            return;
        }
        if (order!.GoodsId <= 0)
        {
            errorMessage = "GoodId is required.";
            return;
        }

        await OrderService.UpdateAsync(Id, order);
        Nav.NavigateTo("/orders");
    }
}
